# ==============================================================================
# CONFIGURACIÓN DE SECRETOS Y APIS - PROYECTO OSINT ML1
# ==============================================================================
# Instrucciones:
# 1. Copia este archivo y cámbiale el nombre a '.env'
# 2. Rellena los valores con tus credenciales personales.
# 3. NUNCA subas el archivo '.env' real al repositorio de Git.
# ==============================================================================

# --- Telegram (Obtener en https://my.telegram.org) ---
TELEGRAM_API_ID=tu_api_id_aqui
TELEGRAM_API_HASH=tu_api_hash_aqui
TELEGRAM_PHONE=+57... # Tu número con código de país

# --- ACLED (Obtener en https://developer.acleddata.com) ---
ACLED_EMAIL=tu_correo@ejemplo.com
ACLED_KEY=tu_api_key_aqui

# --- Apify (Para scraping de X/Twitter - https://apify.com) ---
APIFY_TOKEN=tu_apify_token_aqui

# --- OpenSky Network (Opcional - Tráfico Aéreo) ---
OPENSKY_USERNAME=tu_usuario
OPENSKY_PASSWORD=tu_password

# --- NASA FIRMS (Opcional - Incendios/Explosiones) ---
FIRMS_MAP_KEY=tu_map_key_aqui

# --- UCDP (Uppsala Conflict Data Program - https://ucdp.uu.se/apidocs/) ---
UCDP_TOKEN=tu_token_aqui

# --- Bases de Datos ---
# Si usas MongoDB Atlas (Nube), pega el Connection String aquí:
MONGO_URI=mongodb+srv://usuario:password@cluster.mongodb.net/nombre_db
# Ruta local para la base de datos procesada:
SQLITE_DB_PATH=data/processed/database.sqlite

# --- Configuración del Proyecto ---
ENV=development # development | production
LOG_LEVEL=INFO
